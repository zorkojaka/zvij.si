{"translation-revision-date":"2023-09-12 20:34:53+0000","generator":"GlotPress\/4.0.0-alpha.10","domain":"messages","locale_data":{"messages":{"":{"domain":"messages","plural-forms":"nplurals=4; plural=(n % 100 == 1) ? 0 : ((n % 100 == 2) ? 1 : ((n % 100 == 3 || n % 100 == 4) ? 2 : 3));","lang":"sl_SI"},"WooCommerce Product's Custom Taxonomy Block":["Prilagojen blok taksonomije izdelkov WooCommerce"],"You cannot edit the content of this block. However, you can move it and place other blocks around it.":["Vsebine tega bloka ne morete urediti, lahko pa ga premaknete in obdate z drugimi bloki."],"Classic Template Placeholder":["Vsebnik klasi\u010dne predloge"],"This block represents the classic template used to display the order confirmation. The actual rendered template may appear different from this placeholder.":["Ta blok predstavlja klasi\u010dno predlogo za prikaz potrditve naro\u010dila. Dejanska izrisana predloga se lahko razlikuje od tega vsebnika."],"Order Confirmation Block":["Blok potrditve naro\u010dila"],"Checkout Header":["Glava zaklju\u010dka nakupa"],"Checkout Block":["Blok zaklju\u010dka nakupa"],"WooCommerce Cart Block":["Blok ko\u0161arice WooCommerce"],"Template transformed into blocks!":["Predloga pretvorjena v bloke!"],"Transform into blocks":["Pretvori v bloke"],"Transform this template into multiple blocks so you can add, remove, reorder, and customize your %s template.":["Pretvori to predlogo v ve\u010d blokov, tako da lahko dodate, odstranite, preuredite in prilagodite va\u0161o predlogo %s."],"This block serves as a placeholder for your %s. It will display the actual product image, title, price in your store. You can move this placeholder around and add more blocks around to customize the template.":["Ta blok slu\u017ei kot vsebnik za va\u0161 %s. Prikazal bo dejansko sliko izdelka, naslov in ceno v va\u0161i trgovini. Ta vsebnik lahko premikate in dodate ve\u010d blokov, da prilagodite predlogo."],"Product template":["Predloga izdelka"],"Contains the block elements used to render a product, like its name, featured image, rating, and more.":["Vsebuje predmete blokov, ki so uporabljeni za izris izdelka, kot so ime, prikazna slika, ocena in ve\u010d."],"WooCommerce Product Attribute Block":["Blok atributov izdelkov WooCommerce"],"WooCommerce Product Search Results Block":["Blok rezultatov iskanja izdelkov WooCommerce"],"WooCommerce Classic Template":["Klasi\u010dna predloga WooCommerce"],"WooCommerce Product Grid Block":["Blok mre\u017ee izdelkov WooCommerce"],"WooCommerce Product Tag Block":["Blok oznak izdelkov WooCommerce"],"WooCommerce Single Product Block":["Blok posameznega izdelka WooCommerce"],"WooCommerce Product Taxonomy Block":["Blok taksonomije izdelkov WooCommerce"],"Renders classic WooCommerce PHP templates.":["Izri\u0161e klasi\u010dne PHP predloge WooCommerce."],"Undo":["Razveljavi"],"Order number":["\u0160tevilka naro\u010dila"],"Product Summary":["Povzetek izdelka"],"Display the title of a product.":["Poka\u017eite naslov izdelka."],"Display a short description about a product.":["Poka\u017eite kratek opis izdelka."],"Search products\u2026":["Iskanje izdelkov ..."],"Product Title":["Naziv izdelka"],"Order details":["Podrobnosti naro\u010dila"],"Thank you. Your order has been received.":["Hvala. Va\u0161e naro\u010dilo je bilo sprejeto."],"Billing address":["Naslov pla\u010dnika"],"Shipping address":["Naslov dostave"],"No products were found matching your selection.":["Ujemajo\u010dih izdelkov ni mogo\u010de najti."],"Subtotal":["Delni znesek"],"Order received":["Naro\u010dilo prejeto"],"Date":["Datum"],"Search":["Iskanje"],"Email":["E-po\u0161ta"],"Total":["Znesek"],"WooCommerce":["WooCommerce"],"Product":["Izdelek","Izdelka","Izdelki","Izdelki"]}},"comment":{"reference":"packages\/woocommerce-blocks\/build\/legacy-template.js"}}